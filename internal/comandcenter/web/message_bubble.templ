package web

import (
	"fmt"

	cc "github.com/Abraxas-365/claudio/internal/comandcenter"
)

templ MessageBubble(msg MessageView) {
	if msg.Role == "user" {
		<!-- USER: right-aligned -->
		<div class="msg-row flex justify-end items-center gap-1 mb-1" data-msg-id={ msg.ID } data-session-id={ msg.SessionID }>
			<button class="msg-delete-btn opacity-0 pointer-events-none flex-shrink-0 w-7 h-7 flex items-center justify-center rounded-full hover:bg-red-500/20 text-[var(--color-textMuted)] hover:text-red-400 transition-colors" aria-label="Delete message" type="button">
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M8 6V4a2 2 0 012-2h4a2 2 0 012 2v2m3 0v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6h14"></path></svg>
			</button>
			<div class="msg-bubble-user shadow-sm" style="box-shadow:0 2px 8px rgba(0,0,0,0.4)">
				if msg.ReplyToSession != "" {
					<div class="mb-2 rounded border-l-[3px] border-l-[rgba(255,255,255,0.5)] px-2 py-1 bg-[rgba(255,255,255,0.15)]">
						<p class="text-[11px] font-semibold text-[rgba(255,255,255,0.9)]">{ "@" + msg.ReplyToSession }</p>
						<p class="text-[11px] leading-[1.4] text-[rgba(255,255,255,0.7)]">{ Truncate(80, msg.QuotedContent) }</p>
					</div>
				}
				if msg.Content != "" {
					<p class="text-[var(--color-textPrimary)] text-[15px] leading-[1.5] m-0 whitespace-pre-wrap break-words">{ msg.Content }</p>
				}
				@ImageGrid(FilterImages(msg.Attachments))
				for _, att := range FilterNonImages(msg.Attachments) {
					<a
						href={ templ.SafeURL(fmt.Sprintf("/uploads/%s/%s", att.SessionID, att.Filename)) }
						download={ att.OriginalName }
						class="mt-2 flex items-center gap-2 px-3 py-2 rounded-lg no-underline bg-[rgba(255,255,255,0.2)] text-white text-[13px]"
					>
						<svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
							<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8L14 2z"></path>
							<polyline points="14 2 14 8 20 8" fill="none" stroke="currentColor" stroke-width="1.5"></polyline>
						</svg>
						<span class="truncate max-w-[160px]">{ att.OriginalName }</span>
					</a>
				}
				<p class="text-[var(--color-textMuted)] text-[11px] text-right mt-1">{ RelTime(msg.CreatedAt) }</p>
			</div>
		</div>
	} else if msg.Role == "tool_use" || msg.Role == "tool_call" {
		<!-- TOOL CALL: collapsed by default -->
		<div class="msg-row flex justify-start mb-1" data-msg-id={ msg.ID } data-session-id={ msg.SessionID }>
			<div class="msg-bubble-tool border-l-2 border-l-[var(--color-tool)] cursor-pointer" data-tool-use-id={ msg.ToolUseID }>
				<details ontoggle="this.setAttribute('aria-expanded', this.open)" aria-expanded="false">
					<summary class="cursor-pointer list-none flex items-center gap-2 justify-between px-3 py-2">
						<div class="flex items-center gap-2">
							<svg class="flex-shrink-0" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--color-tool)" stroke-width="2.5"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"></path></svg>
							<span class="text-[var(--color-tool)] text-[13px] font-semibold">{ ToolName(msg.Content) }</span>
							if msg.AgentName != "" {
								<span class="text-[var(--color-textMuted)] text-[11px]">· { msg.AgentName }</span>
							}
						</div>
						<svg class="tool-chevron flex-shrink-0 transition-transform duration-200" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--color-textMuted)" stroke-width="2"><path d="M9 5l7 7-7 7"></path></svg>
					</summary>
					<div class="tool-sections px-3 pb-3 pt-1 space-y-2">
						if ToolInput(msg.Content) != "" {
							<details>
								<summary class="text-[11px] font-semibold text-[var(--color-textMuted)] mb-1 cursor-pointer list-none flex items-center gap-1 select-none uppercase tracking-[0.8px]">▾ Input</summary>
								<div class="bg-[#0B0E0F] rounded-[6px] px-3 py-2">
									<pre class="text-[13px] overflow-x-auto overflow-y-auto whitespace-pre-wrap text-[var(--color-textSecondary)] max-h-[200px] m-0 max-w-full box-border">{ ToolInput(msg.Content) }</pre>
								</div>
							</details>
						}
						if msg.Output != "" {
							<details class="tool-output-section">
								<summary class="text-[11px] font-semibold text-[var(--color-textMuted)] mb-1 cursor-pointer list-none flex items-center gap-1 select-none uppercase tracking-[0.8px]">▾ Output</summary>
								<div class="bg-[#071a10] rounded-[6px] px-3 py-2 border-l-2 border-l-[var(--color-brand)]">
									<pre class="text-[13px] overflow-x-auto overflow-y-auto whitespace-pre-wrap text-[var(--color-textPrimary)] max-h-[200px] m-0 max-w-full box-border">{ msg.Output }</pre>
								</div>
							</details>
						} else {
							<div class="text-[var(--color-textMuted)] text-[11px] font-semibold uppercase tracking-[0.8px] mb-1">Output</div>
							<div class="flex gap-1 px-3 py-2 items-center">
								<span class="tool-dot"></span>
								<span class="tool-dot"></span>
								<span class="tool-dot"></span>
							</div>
						}
					</div>
				</details>
			</div>
		</div>
	} else if msg.Role == "tool_result" {
		<!-- TOOL RESULT: indented, muted -->
		<div class="msg-row flex justify-start mb-1 ml-8" data-msg-id={ msg.ID } data-session-id={ msg.SessionID }>
			<div class="max-w-[80%] px-2 py-1 rounded-lg text-[11px] bg-[var(--color-surfaceHigh)] text-[var(--color-textMuted)]">
				{ msg.Content }
			</div>
		</div>
	} else if msg.Role == "error" {
		<!-- ERROR: red-tinted with warning icon -->
		<div class="msg-row flex justify-start mb-2" data-msg-id={ msg.ID } data-session-id={ msg.SessionID }>
			<div class="flex items-start gap-2 max-w-[80%] px-[14px] py-[10px] rounded-xl bg-[rgba(224,80,80,0.10)] border border-[var(--color-error)]">
				<span class="flex-shrink-0 mt-0.5">⚠</span>
				<div class="min-w-0">
					<p class="text-sm text-[var(--color-error)]">{ msg.Content }</p>
					<p class="text-[11px] mt-1 text-[var(--color-textMuted)]">{ RelTime(msg.CreatedAt) }</p>
				</div>
			</div>
		</div>
	} else if msg.Role == "bundle" {
		<!-- BUNDLE CARD: left-aligned design card -->
		<div class="msg-row flex flex-col items-start mb-1" data-msg-id={ msg.ID } data-session-id={ msg.SessionID }>
			<div class="max-w-[min(520px,85%)] rounded-xl overflow-hidden border border-[#3A3A3C] border-l-[3px] border-l-[#BF5AF2] bg-[#1C1C1E] [box-shadow:0_2px_8px_rgba(0,0,0,0.4)]">
				<div class="px-[14px] py-3">
					<div class="flex items-center gap-2 mb-1">
						<span class="text-[18px]">🎨</span>
						<p class="text-sm font-bold text-[var(--color-textPrimary)] m-0">Mockup Bundle Ready</p>
					</div>
					if msg.AgentName != "" {
						<p class="text-xs text-[var(--color-textMuted)] m-0 mb-[10px] ml-[26px]">{ msg.AgentName }</p>
					}
					<a
						href={ templ.SafeURL(msg.Content) }
						target="_blank"
						rel="noopener noreferrer"
						class="block mt-[10px] px-[14px] py-2 rounded-lg bg-[#0A84FF] text-white text-[13px] font-semibold text-center no-underline"
					>Open Bundle →</a>
				</div>
			</div>
			<p class="text-[var(--color-textMuted)] text-[11px] mt-1 pl-[2px]">{ RelTime(msg.CreatedAt) }</p>
		</div>
	} else if IsAgentStatusLine(msg.Content) {
		<!-- AGENT STATUS: compact collapsed group -->
		<details class="msg-row mb-1 px-2 py-1 opacity-50 group" data-msg-id={ msg.ID } data-session-id={ msg.SessionID }>
			<summary class="flex items-center gap-2 cursor-pointer list-none text-[var(--color-textMuted)] text-[12px] hover:opacity-80">
				<span class="inline-block w-2 h-2 rounded-full bg-[var(--color-ai)]"></span>
				<span>{ fmt.Sprintf("%d agents completed", CountStatusLines(msg.Content)) }</span>
				<span class="text-[10px]">{ RelTime(msg.CreatedAt) }</span>
			</summary>
			<div class="pl-4 pt-1 text-[var(--color-textMuted)] text-[11px] leading-relaxed">
				for _, line := range StatusLines(msg.Content) {
					<div>{ line }</div>
				}
			</div>
		</details>
	} else {
		<!-- ASSISTANT / CRON: left-aligned -->
		<div class="msg-row flex flex-col items-start mb-1 group/msg" data-msg-id={ msg.ID } data-session-id={ msg.SessionID }>
			if msg.AgentName != "" {
				if HasPrefix(msg.AgentName, "⏰") {
					<p class="text-[var(--color-cron)] text-[11px] font-semibold mb-1 tracking-[0.5px] pl-[2px]">{ msg.AgentName }</p>
				} else {
					<p class="text-[var(--color-ai)] text-[11px] font-semibold mb-1 tracking-[0.5px] pl-[2px]">{ msg.AgentName }</p>
				}
			}
			if msg.AgentName != "" && HasPrefix(msg.AgentName, "⏰") {
				<div class="msg-bubble-cron shadow-sm" style="box-shadow:0 2px 8px rgba(0,0,0,0.4)">
					<div class="md-content text-[var(--color-textPrimary)] text-[15px] leading-[1.5]">
						@templ.Raw(string(RenderMD(msg.Content)))
					</div>
					@ImageGrid(FilterImages(msg.Attachments))
					for _, att := range FilterNonImages(msg.Attachments) {
						@assistantAttachment(att)
					}
				</div>
			} else {
				<div class="flex items-center gap-1">
					<div class="msg-bubble-assistant shadow-sm min-w-0" style="box-shadow:0 2px 8px rgba(0,0,0,0.4)">
						<div class="md-content text-[var(--color-textPrimary)] text-[15px] leading-[1.5]">
							@templ.Raw(string(RenderMD(msg.Content)))
						</div>
						@ImageGrid(FilterImages(msg.Attachments))
						for _, att := range FilterNonImages(msg.Attachments) {
							@assistantAttachment(att)
						}
					</div>
					<button class="msg-delete-btn opacity-0 pointer-events-none flex-shrink-0 w-7 h-7 flex items-center justify-center rounded-full hover:bg-red-500/20 text-[var(--color-textMuted)] hover:text-red-400 transition-colors" aria-label="Delete message" type="button">
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M8 6V4a2 2 0 012-2h4a2 2 0 012 2v2m3 0v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6h14"></path></svg>
					</button>
				</div>
			}
			<p class="text-[var(--color-textMuted)] text-[11px] mt-1 pl-[2px]">{ RelTime(msg.CreatedAt) }</p>
		</div>
	}
}

templ SkeletonBubble(side string) {
	if side == "left" {
		<div class="flex justify-start px-4 py-1">
			<div class="max-w-[70%] flex flex-col gap-[6px]">
				<div class="h-[14px] rounded-lg w-[200px] skeleton-shimmer"></div>
				<div class="h-[14px] rounded-lg w-[150px] skeleton-shimmer"></div>
				<div class="h-[14px] rounded-lg w-[100px] skeleton-shimmer"></div>
			</div>
		</div>
	} else {
		<div class="flex justify-end px-4 py-1">
			<div class="max-w-[70%] flex flex-col gap-[6px]">
				<div class="h-[14px] rounded-lg w-[200px] skeleton-shimmer"></div>
				<div class="h-[14px] rounded-lg w-[150px] skeleton-shimmer"></div>
				<div class="h-[14px] rounded-lg w-[100px] skeleton-shimmer"></div>
			</div>
		</div>
	}
}

templ assistantAttachment(att cc.Attachment) {
	<a
		href={ templ.SafeURL(fmt.Sprintf("/uploads/%s/%s", att.SessionID, att.Filename)) }
		download={ att.OriginalName }
		class="mt-2 flex items-center gap-2 px-3 py-2 rounded-lg no-underline bg-[rgba(255,255,255,0.08)] text-[var(--color-textPrimary)] text-[13px]"
	>
		<svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
			<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8L14 2z"></path>
			<polyline points="14 2 14 8 20 8" fill="none" stroke="currentColor" stroke-width="1.5"></polyline>
		</svg>
		<span class="truncate max-w-[160px]">{ att.OriginalName }</span>
	</a>
}

// ImageGrid renders a WhatsApp-style multi-image collage.
// Supports 1, 2, 3, 4, and 5+ image layouts.
templ ImageGrid(images []cc.Attachment) {
	if len(images) > 0 {
		<div class="mt-2 max-w-[280px] rounded-xl overflow-hidden">
			if len(images) == 1 {
				<!-- single: full width, 4:3 -->
				<div class="relative w-full aspect-[4/3] overflow-hidden rounded-[4px]">
					<img
						src={ imgURL(images[0]) }
						alt={ images[0].OriginalName }
						class="w-full h-full object-cover cursor-pointer block"
						loading="lazy"
						onclick="ccOpenLightbox(this.src,event)"
					/>
				</div>
			} else if len(images) == 2 {
				<!-- two equal columns, 140px height -->
				<div class="flex gap-[2px] h-[140px]">
					<div class="flex-1 overflow-hidden rounded-[4px]">
						<img
							src={ imgURL(images[0]) }
							alt={ images[0].OriginalName }
							class="w-full h-full object-cover cursor-pointer block"
							loading="lazy"
							onclick="ccOpenLightbox(this.src,event)"
						/>
					</div>
					<div class="flex-1 overflow-hidden rounded-[4px]">
						<img
							src={ imgURL(images[1]) }
							alt={ images[1].OriginalName }
							class="w-full h-full object-cover cursor-pointer block"
							loading="lazy"
							onclick="ccOpenLightbox(this.src,event)"
						/>
					</div>
				</div>
			} else if len(images) == 3 {
				<!-- left 2/3 full height, right 1/3 stacked -->
				<div class="flex gap-[2px] h-[200px]">
					<div class="[flex:2] overflow-hidden rounded-[4px]">
						<img
							src={ imgURL(images[0]) }
							alt={ images[0].OriginalName }
							class="w-full h-full object-cover cursor-pointer block"
							loading="lazy"
							onclick="ccOpenLightbox(this.src,event)"
						/>
					</div>
					<div class="flex-1 flex flex-col gap-[2px]">
						<div class="flex-1 overflow-hidden rounded-[4px]">
							<img
								src={ imgURL(images[1]) }
								alt={ images[1].OriginalName }
								class="w-full h-full object-cover cursor-pointer block"
								loading="lazy"
								onclick="ccOpenLightbox(this.src,event)"
							/>
						</div>
						<div class="flex-1 overflow-hidden rounded-[4px]">
							<img
								src={ imgURL(images[2]) }
								alt={ images[2].OriginalName }
								class="w-full h-full object-cover cursor-pointer block"
								loading="lazy"
								onclick="ccOpenLightbox(this.src,event)"
							/>
						</div>
					</div>
				</div>
			} else {
				<!-- 4 or 5+: 2×2 grid -->
				<div class="grid grid-cols-2 gap-[2px]">
					<!-- cell 0 -->
					<div class="h-[140px] overflow-hidden rounded-[4px]">
						<img
							src={ imgURL(images[0]) }
							alt={ images[0].OriginalName }
							class="w-full h-full object-cover cursor-pointer block"
							loading="lazy"
							onclick="ccOpenLightbox(this.src,event)"
						/>
					</div>
					<!-- cell 1 -->
					<div class="h-[140px] overflow-hidden rounded-[4px]">
						<img
							src={ imgURL(images[1]) }
							alt={ images[1].OriginalName }
							class="w-full h-full object-cover cursor-pointer block"
							loading="lazy"
							onclick="ccOpenLightbox(this.src,event)"
						/>
					</div>
					<!-- cell 2 -->
					<div class="h-[140px] overflow-hidden rounded-[4px]">
						<img
							src={ imgURL(images[2]) }
							alt={ images[2].OriginalName }
							class="w-full h-full object-cover cursor-pointer block"
							loading="lazy"
							onclick="ccOpenLightbox(this.src,event)"
						/>
					</div>
					<!-- cell 3: plain for n==4, overlay for n>=5 -->
					if len(images) == 4 {
						<div class="h-[140px] overflow-hidden rounded-[4px]">
							<img
								src={ imgURL(images[3]) }
								alt={ images[3].OriginalName }
								class="w-full h-full object-cover cursor-pointer block"
								loading="lazy"
								onclick="ccOpenLightbox(this.src,event)"
							/>
						</div>
					} else {
						<!-- +N overlay cell -->
						<div
							class="h-[140px] overflow-hidden rounded-[4px] relative cursor-pointer"
							data-src={ imgURL(images[3]) }
							onclick="ccOpenLightbox(this.dataset.src,event)"
						>
							<img
								src={ imgURL(images[3]) }
								alt={ images[3].OriginalName }
								class="w-full h-full object-cover block pointer-events-none"
								loading="lazy"
							/>
							<div class="absolute inset-0 bg-[rgba(0,0,0,0.6)] flex items-center justify-center pointer-events-none rounded-[4px]">
								<span class="text-white text-[22px] font-bold">+{ itoa(len(images) - 4) }</span>
							</div>
						</div>
					}
				</div>
			}
		</div>
		@ccLightboxScript()
	}
}

// ccLightboxScript emits a lightweight full-screen lightbox — idempotent (guard on window.ccOpenLightbox).
templ ccLightboxScript() {
	<script>
	(function(){
		if(window.ccOpenLightbox)return;
		function getLightbox(){
			var lb=document.getElementById('cc-lightbox');
			if(!lb){
				lb=document.createElement('div');
				lb.id='cc-lightbox';
				lb.style.cssText='display:none;position:fixed;inset:0;z-index:500;background:rgba(0,0,0,0.92);align-items:center;justify-content:center;cursor:pointer;';
				var img=document.createElement('img');
				img.id='cc-lightbox-img';
				img.style.cssText='max-width:90vw;max-height:90vh;object-fit:contain;border-radius:8px;pointer-events:none;';
				lb.appendChild(img);
				lb.addEventListener('click',function(e){
					if(e.target===lb||e.target.id==='cc-lightbox'){lb.style.display='none';}
				});
				document.body.appendChild(lb);
			}
			return lb;
		}
		window.ccOpenLightbox=function(src,event){
			if(event){event.stopPropagation();}
			var lb=getLightbox();
			document.getElementById('cc-lightbox-img').src=src;
			lb.style.display='flex';
		};
		document.addEventListener('keydown',function(e){
			if(e.key==='Escape'){
				var lb=document.getElementById('cc-lightbox');
				if(lb)lb.style.display='none';
			}
		});
	})();
	</script>
}
