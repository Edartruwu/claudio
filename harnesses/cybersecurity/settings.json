{
  "mcpServers": {
    "semgrep": {
      "command": "npx",
      "args": ["-y", "@semgrep/mcp-server"],
      "type": "stdio"
    },
    "snyk": {
      "command": "npx",
      "args": ["-y", "snyk-mcp-server"],
      "env": {
        "SNYK_TOKEN": ""
      },
      "type": "stdio"
    },
    "shodan": {
      "command": "npx",
      "args": ["-y", "shodan-mcp-server"],
      "env": {
        "SHODAN_API_KEY": ""
      },
      "type": "stdio"
    },
    "wiremcp": {
      "command": "npx",
      "args": ["-y", "wiremcp"],
      "type": "stdio"
    }
  }
}
