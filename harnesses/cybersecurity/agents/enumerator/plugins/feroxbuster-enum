#!/usr/bin/env bash

if [ "$1" = "--describe" ]; then
  cat <<EOF
{
  "name": "feroxbuster-enum",
  "description": "Directory enumeration using Feroxbuster. Finds directories and files on web servers.",
  "version": "1.0.0"
}
EOF
  exit 0
fi

if [ "$1" = "--schema" ]; then
  cat <<EOF
{
  "type": "object",
  "required": ["url"],
  "properties": {
    "url": {
      "type": "string",
      "description": "Target URL to enumerate"
    },
    "wordlist": {
      "type": "string",
      "description": "Path to wordlist file"
    },
    "extensions": {
      "type": "array",
      "items": {"type": "string"},
      "description": "File extensions to test (e.g. php, html, txt)"
    },
    "threads": {
      "type": "integer",
      "description": "Number of concurrent threads",
      "default": 50
    },
    "depth": {
      "type": "integer",
      "description": "Maximum recursion depth",
      "default": 4
    },
    "status_codes": {
      "type": "array",
      "items": {"type": "integer"},
      "description": "Status codes to report (default 2xx, 3xx)"
    }
  }
}
EOF
  exit 0
fi

# Check feroxbuster exists
if ! command -v feroxbuster &> /dev/null; then
  echo "Error: feroxbuster not found in PATH" >&2
  exit 1
fi

# Parse JSON input from stdin
input=$(cat)
url=$(echo "$input" | jq -r '.url')
wordlist=$(echo "$input" | jq -r '.wordlist // empty')
extensions=$(echo "$input" | jq -r '.extensions // [] | join(",")')
threads=$(echo "$input" | jq -r '.threads // 50')
depth=$(echo "$input" | jq -r '.depth // 4')
status_codes=$(echo "$input" | jq -r '.status_codes // [] | join(",")')

if [ -z "$url" ]; then
  echo "Error: url required" >&2
  exit 1
fi

args=("-u" "$url")

if [ -n "$wordlist" ]; then
  args+=("-w" "$wordlist")
fi

if [ -n "$extensions" ] && [ "$extensions" != "" ]; then
  args+=("-x" "$extensions")
fi

args+=("-t" "$threads" "-d" "$depth")

if [ -n "$status_codes" ] && [ "$status_codes" != "" ]; then
  args+=("-s" "$status_codes")
fi

feroxbuster "${args[@]}"
